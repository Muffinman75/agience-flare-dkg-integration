# =============================================================================
# Agience DKG Integration - environment template
# =============================================================================
# Copy this file to `.env` in this directory (integration/package/.env) and fill
# in values. The CLI (`agience-dkg`) and MCP server (`agience-dkg-mcp`) auto-load
# this file at startup, so you don't have to re-export variables every shell.
#
# Existing shell exports take precedence over .env values, so you can still
# override per-command if needed.
# =============================================================================

# --- DKG transport (daemon is the default and canonical Round 1 path) -------
# 'daemon' = direct HTTP to the local OriginTrail DKG v10 daemon (recommended)
# 'mcp'    = MCP Streamable HTTP to a DKG node's /mcp endpoint (e.g. one
#            fronted by `dkg mcp setup`, or the dkg-node/apps/agent reference
#            node)
DKG_TRANSPORT=daemon

# --- Daemon transport (DKG_TRANSPORT=daemon) --------------------------------
# Local DKG v10 daemon URL. 9201 (rather than the daemon's default 9200) avoids
# colliding with Windows Elasticsearch on the same machine.
DKG_BASE_URL=http://127.0.0.1:9201

# Daemon bearer token. Auto-read from ~/.dkg/auth.token if unset, so you can
# leave this blank on a default `dkg init` install.
# DKG_DAEMON_TOKEN=

# --- MCP transport (DKG_TRANSPORT=mcp) --------------------------------------
# Only needed when running against an MCP-fronted DKG node. The bearer token
# is the MCP-flavour token for that node, not the daemon's auth.token.
# DKG_BASE_URL=http://localhost:8083  # uncomment + override DKG_BASE_URL above
# DKG_TOKEN=<your-mcp-bearer-token>

# --- Common ------------------------------------------------------------------
# Default Context Graph ID for `agience-dkg wm-write` / `promote` / `search`.
DKG_CONTEXT_GRAPH=agience-demo

# --- Agience backend (governed mode: --from-agience-artifact) ---------------
# Used when the CLI fetches a committed artifact before projecting it to DKG.
#
# ⚠️ WSL2 NOTE: if you run this CLI from WSL but Agience runs on Windows, set
# this to your Windows host IP, NOT localhost. Find it with:
#     ip route show | awk '/default/ {print $3}'
# Then for example: AGIENCE_BASE_URL=http://172.24.80.1:8081
AGIENCE_BASE_URL=http://localhost:8081

# Agience API key (starts with `agc_`). Mint via the UI or `POST /api-keys`.
# Leave blank if you never use --from-agience-artifact.
AGIENCE_TOKEN=
